{
  "name": "kappa-brain",
  "version": "1.0.0",
  "description": "kappa-brain — MCP server for Kappa Cell memory: 21 tools, FTS5 + sqlite-vec, supersede system",
  "type": "module",
  "bin": {
    "kappa-brain": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "start": "bun dist/server.js",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.12.5",
    "@hono/node-server": "^1.13.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.5.0"
  }
}