{
  "name": "@kappa-brain/brain-cli",
  "version": "2.0.2",
  "description": "Kappa Cell brain — MCP server (29 tools) + skill installer (14 pure kappa skills) + vault sync + Cerebro lineage",
  "type": "module",
  "bin": {
    "brain-cli": "dist/index.js"
  },
  "files": [
    "dist/**"
  ],
  "keywords": [
    "kappa",
    "mcp",
    "brain",
    "cerebro",
    "kappanet",
    "skill-installer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doctorboyz/kappa-brain.git"
  },
  "author": "doctorboyz",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target bun && cp -r src/skills dist/skills && cp -r src/agents dist/agents",
    "start": "bun dist/index.js",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^12.0.0",
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
